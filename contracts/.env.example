# Copy to .env and fill in. Never commit real secrets.
# Deployer private key (0x...) OR use MNEMONIC below.
PRIVATE_KEY=
MNEMONIC=

# Sepolia RPC (Infura/Alchemy/public). A public default is used if unset.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# For contract verification.
ETHERSCAN_API_KEY=
