# Copy to .env.local

# Set to 1 to force the in-memory demo (no testnet needed). The app also
# auto-uses demo mode when contract addresses below are unset.
NEXT_PUBLIC_DEMO=1

# Sepolia RPC for reads (public default used if unset)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployed contract addresses (written by `pnpm deploy:sepolia` to
# lib/contracts/addresses.<chainId>.json — copy them here to go live).
NEXT_PUBLIC_CUSD_ADDRESS=
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_PAY_ADDRESS=
NEXT_PUBLIC_AUDIT_ADDRESS=

# Block the contracts were deployed at (speeds up history log queries)
NEXT_PUBLIC_DEPLOY_BLOCK=0
